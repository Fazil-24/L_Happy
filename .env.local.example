# Copy this file to .env.local and add your keys

# Cerebras API (primary LLM — free tier, 1M tokens/day)
# Get your key at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# If your network uses a corporate proxy or custom root CA, point this to a PEM file.
# CEREBRAS_CA_CERT_PATH=C:\path\to\corp-root-ca.pem

# SerpAPI (optional — web search for competitor & market intel)
# If absent, the app skips web search and uses LLM knowledge only
# Get your key at: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here
